    {
      "type": "node",
      "request": "launch",
      "name": "Run Database Sanity Tests",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/test_server.js",
      "console": "integratedTerminal"
    }
  ]
}
